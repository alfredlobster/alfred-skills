{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/alfredlobster/alfred-skills/schemas/use-case-points/rup-actor-catalog.schema.json",
  "title": "Use Case Point Estimation - RUP Actor Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "actors"],
  "properties": {
    "version": { "type": "string", "const": "ucp-rup-actors-v1" },
    "actors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "description", "classification"],
        "properties": {
          "id": { "type": "string", "pattern": "^ACT[0-9]+$" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "classification": { "type": "string", "enum": ["simple", "average", "complex", "unclassified"] },
          "classification_rationale": { "type": "string" }
        }
      }
    }
  }
}
