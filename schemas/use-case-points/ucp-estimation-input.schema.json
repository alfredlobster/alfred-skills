{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/alfredlobster/alfred-skills/schemas/use-case-points/ucp-estimation-input.schema.json",
  "title": "Use Case Point Estimation Input",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "actor_catalog", "use_case_specs", "tcf_ratings", "ecf_ratings"],
  "properties": {
    "version": { "type": "string", "const": "ucp-estimation-input-v1" },
    "actor_catalog": { "type": "string", "description": "Path or embedded reference to RUP actor catalog artifact" },
    "use_case_specs": { "type": "string", "description": "Path or embedded reference to RUP use-case specifications artifact" },
    "tcf_ratings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "T1": {"type":"number","minimum":0,"maximum":5},"T2": {"type":"number","minimum":0,"maximum":5},"T3": {"type":"number","minimum":0,"maximum":5},"T4": {"type":"number","minimum":0,"maximum":5},"T5": {"type":"number","minimum":0,"maximum":5},"T6": {"type":"number","minimum":0,"maximum":5},"T7": {"type":"number","minimum":0,"maximum":5},"T8": {"type":"number","minimum":0,"maximum":5},"T9": {"type":"number","minimum":0,"maximum":5},"T10": {"type":"number","minimum":0,"maximum":5},"T11": {"type":"number","minimum":0,"maximum":5},"T12": {"type":"number","minimum":0,"maximum":5},"T13": {"type":"number","minimum":0,"maximum":5}
      },
      "required": ["T1","T2","T3","T4","T5","T6","T7","T8","T9","T10","T11","T12","T13"]
    },
    "ecf_ratings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "E1": {"type":"number","minimum":0,"maximum":5},"E2": {"type":"number","minimum":0,"maximum":5},"E3": {"type":"number","minimum":0,"maximum":5},"E4": {"type":"number","minimum":0,"maximum":5},"E5": {"type":"number","minimum":0,"maximum":5},"E6": {"type":"number","minimum":0,"maximum":5},"E7": {"type":"number","minimum":0,"maximum":5},"E8": {"type":"number","minimum":0,"maximum":5}
      },
      "required": ["E1","E2","E3","E4","E5","E6","E7","E8"]
    },
    "productivity_factor_hours_per_ucp": { "type": ["number", "null"], "minimum": 0 }
  }
}
